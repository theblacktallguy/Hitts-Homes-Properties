generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Property {
  id                 String   @id @default(cuid())
  propertyId         String   @unique
  title              String
  state              String
  city               String
  createdAt          DateTime @default(now())
  address            String
  agentName          String?
  amenities          Json?
  applicationEnabled Boolean  @default(true)
  bathrooms          Float?
  bedrooms           Int
  construction       Json?
  contactEmail       String?
  contactPhone       String?
  descriptionShort   String
  factsFeatures      Json?
  financial          Json?
  imageFolder        String
  listingType        String
  lot                Json?
  price              Int
  propertyType       String
  sqft               Int
  status             String
  updatedAt          DateTime @updatedAt
  utilities          Json?
  videoUrl           String?
  virtualTourUrl     String?
  zipCode            String?
  petFriendly Boolean @default(false)
}

model RentalApplication {
  id                 String   @id @default(cuid())
  fullName           String
  email              String
  phone              String
  propertyId         String
  propertyTitle      String
  propertyAddress    String
  desiredMoveInDate  String
  leaseTerm          String
  status             String   @default("pending")
  decisionNote       String?
  applicationFee     Int?
  additionalFees     Int?
  decidedAt          DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([status, createdAt])
  @@index([propertyId])
}

model TourRequest {
  id                String   @id @default(cuid())
  fullName          String
  email             String
  phone             String
  propertyId        String
  propertyTitle     String
  propertyAddress   String
  tourType          String
  preferredDate     String
  preferredTime     String
  alternateDate     String?
  alternateTime     String?
  status            String   @default("pending")
  decisionNote      String?
  confirmedDate     String?
  confirmedTime     String?
  decidedAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([status, createdAt])
  @@index([propertyId])
}
